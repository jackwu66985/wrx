page {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.08);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  background: #e5e7eb;
  color: #374151;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}
